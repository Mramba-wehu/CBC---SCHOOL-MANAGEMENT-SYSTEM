{
  "name": "wehu-cbc-sms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=web\"",
    "install-all": "npm install && npm install --workspace=backend && npm install --workspace=web",
    "seed": "npm run seed --workspace=backend",
    "build": "npm run build --workspace=web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
