<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 40px; color: #333; }
        .header { text-align: center; border-bottom: 3px solid #6366f1; padding-bottom: 20px; margin-bottom: 30px; }
        .school-name { font-size: 28px; font-weight: bold; color: #6366f1; text-transform: uppercase; }
        .report-title { font-size: 20px; color: #64748b; margin-top: 5px; }
        
        .student-info { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; background: #f8fafc; padding: 20px; border-radius: 10px; }
        .info-item { display: flex; gap: 10px; font-size: 14px; }
        .label { font-weight: bold; color: #64748b; min-width: 120px; }
        
        .subject-section { margin-bottom: 40px; }
        .subject-header { background: #6366f1; color: white; padding: 10px 15px; border-radius: 5px; font-size: 18px; font-weight: bold; margin-bottom: 15px; }
        
        table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
        th, td { border: 1px solid #e2e8f0; padding: 12px; text-align: left; font-size: 13px; }
        th { background: #f1f5f9; color: #475569; }
        
        .rating-cell { text-align: center; font-weight: bold; width: 60px; }
        .rating-EE { color: #10b981; }
        .rating-ME { color: #0ea5e9; }
        .rating-AE { color: #f59e0b; }
        .rating-BE { color: #ef4444; }
        
        .comments-box { margin-top: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .comment-item { border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; }
        .comment-title { font-weight: bold; color: #6366f1; margin-bottom: 10px; font-size: 14px; border-bottom: 1px solid #f1f5f9; padding-bottom: 5px; }
        .comment-text { font-style: italic; color: #475569; font-size: 13px; }
        
        .footer { margin-top: 50px; text-align: center; border-top: 1px solid #e2e8f0; padding-top: 20px; font-size: 12px; color: #94a3b8; }
        .signature-row { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; margin-top: 50px; text-align: center; }
        .signature-line { border-top: 1px solid #333; padding-top: 5px; margin-top: 40px; }
        
        .page-break { page-break-after: always; }
    </style>
</head>
<body>
    <div className="header">
        <div className="school-name">Wehu CBC School</div>
        <div className="report-title">Summative Performance Report</div>
        <div>Term <%= report.term.termNumber %> - <%= report.term.academicYear.year %></div>
    </div>

    <div className="student-info">
        <div className="info-item"><span className="label">Student Name:</span> <span><%= report.student.firstName %> <%= report.student.lastName %></span></div>
        <div className="info-item"><span className="label">Admission No:</span> <span><%= report.student.studentId %></span></div>
        <div className="info-item"><span className="label">Grade/Stream:</span> <span><%= report.student.stream.grade.name %> <%= report.student.stream.name %></span></div>
        <div className="info-item"><span className="label">Days Present:</span> <span><%= report.attendanceStats.present %> / <%= report.attendanceStats.total %></span></div>
    </div>

    <% report.subjects.forEach(subject => { %>
        <div className="subject-section">
            <div className="subject-header"><%= subject.subjectName %> (Overall: <%= subject.overallRating %>)</div>
            <% subject.strands.forEach(strand => { %>
                <h4 style="color: #475569; margin: 10px 0;"><%= strand.name %></h4>
                <table>
                    <thead>
                        <tr>
                            <th>Learning Outcome / Sub-strand</th>
                            <th className="rating-cell">Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% strand.ratings.forEach(r => { %>
                            <tr>
                                <td>
                                    <div style="font-weight: 500;"><%= r.subStrand %></div>
                                    <div style="font-size: 11px; color: #64748b;"><%= r.outcome %></div>
                                </td>
                                <td className="rating-cell rating-<%= r.rating %>"><%= r.rating %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% }) %>
        </div>
    <% }) %>

    <div className="comments-box">
        <div className="comment-item">
            <div className="comment-title">Class Teacher's Comments</div>
            <div className="comment-text"><%= comments.teacherComments || 'Work harder next term.' %></div>
        </div>
        <div className="comment-item">
            <div className="comment-title">Principal's Remarks</div>
            <div className="comment-text"><%= comments.principalComments || 'A consistent performance. Keep it up!' %></div>
        </div>
    </div>

    <div className="signature-row">
        <div>
            <div className="signature-line">Class Teacher Signature</div>
        </div>
        <div>
            <div className="signature-line">School Principal Signature</div>
        </div>
    </div>

    <div className="footer">
        &copy; <%= new Date().getFullYear() %> Wehu CBC School Management System. This is a computer-generated document.
    </div>
</body>
</html>
